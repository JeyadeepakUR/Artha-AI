# ------------------------------------------------------------
# Artha AI - Environment Template
# Copy this file to `.env` (or `.env.local`) and fill real values.
# Never commit real secrets.
# ------------------------------------------------------------

# Database
# SQLite local example:
DATABASE_URL="file:./dev.db"

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY"
# Optional alias used by this codebase as fallback for anon key:
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY="YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY"

# ------------------------------------------------------------
# Hosted LLM provider (OpenRouter / OpenAI-compatible)
# ------------------------------------------------------------
OPENROUTER_API_KEY="YOUR_OPENROUTER_API_KEY"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_MODELS="arcee-ai/trinity-large-preview:free,nvidia/nemotron-3-super-120b-a12b:free,nvidia/nemotron-3-nano-30b-a3b:free"

# Optional OpenAI-compatible fallback path used by chat route
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o-mini"

# Required by OpenRouter headers and app callback logic
APP_BASE_URL="http://localhost:3000"

# ------------------------------------------------------------
# Local LLM mode (Ollama) - optional
# ------------------------------------------------------------
# true/false flags (string values)
OLLAMA_ENABLED="false"
# true = Ollama first; false = hosted LLM first
OLLAMA_PREFERRED="false"
OLLAMA_BASE_URL="http://127.0.0.1:11434"
# Must match a model installed locally (`ollama list`)
OLLAMA_MODEL="codestral:latest"
